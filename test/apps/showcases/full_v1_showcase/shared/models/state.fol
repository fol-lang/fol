typ[exp] Report: rec = {
    title: str;
    owner: str;
    status: Status;
    status_code: int;
    size: int
};

fun[exp] build_report(flag: bol): Report = {
    var current: User = lead();
    var names_local: seq[str] = names();
    return {
        title = [uwp]pick_label(true),
        owner = current.name,
        status = okay_status(flag),
        status_code = status_code(flag),
        size = .len(names_local),
    };
};

fun[exp] report_code(report: Report): int = {
    when(report.status_code) {
        case(1) { return 7; }
        case(2) { return 3; }
        * { return 1; }
    }
};

fun[exp] owner_size(report: Report): int = {
    return .len(report.owner);
};
