pro[] build(): non = {
    var build = .build();
    build.meta({
        name = "logtiny",
        version = "0.1.4",
    });
    var graph = build.graph();
    var root = graph.add_module({
        name = "root",
        root = "src/lib.fol",
    });
    var target = graph.standard_target();
    var optimize = graph.standard_optimize();
    var lib = graph.add_static_lib({
        name = "logtiny",
        root = "src/lib.fol",
        target = target,
        optimize = optimize,
        fol_model = "memo",
    });
    var app = graph.add_exe({
        name = "logtiny-demo",
        root = "src/main.fol",
        target = target,
        optimize = optimize,
        fol_model = "memo",
    });

    build.export_module({
        name = "root",
        module = root,
    });
    build.export_artifact({
        name = "runtime",
        artifact = lib,
    });
    graph.install(lib);
    graph.install(app);
    graph.add_run(app);
    graph.step("docs");
    graph.step("lint");
    return;
};
