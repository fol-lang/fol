pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_proc_spawn_in_core_m1", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-proc-spawn-in-core-m1",
        root = "src/main.fol",
        fol_model = "core",
    });
    graph.install(app);
    return;
};
