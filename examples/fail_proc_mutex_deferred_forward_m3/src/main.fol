use std: pkg = {"std"};

typ Counter: rec = {
    value: int,
};

fun[] leaf(counter[mux]: Counter): int = {
    counter.lock();
    var value: int = counter.value;
    counter.unlock();
    return value;
};

fun[] inspect(counter[mux]: Counter): int = {
    counter.lock();
    dfr {
        var delayed: int = leaf(counter);
    };
    return 0;
};

fun[] main(): int = {
    var counter: Counter = { value = 1 };
    return inspect(counter);
};
