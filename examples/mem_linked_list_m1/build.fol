pro[] build(): non = {
    var build = .build();
    build.meta({ name = "mem_linked_list_m1", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "mem-linked-list-m1",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
