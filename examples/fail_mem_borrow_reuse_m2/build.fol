pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_mem_borrow_reuse_m2", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-mem-borrow-reuse-m2",
        root = "src/main.fol",
        fol_model = "core",
    });
    graph.install(app);
    return;
};
