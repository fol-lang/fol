pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_mem_explicit_move_reuse_m1", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({ name = "fail-mem-explicit-move-reuse-m1", root = "src/main.fol", fol_model = "memo" });
