use std: pkg = {"std"};

std geo: pro = {
    fun area(): int;
};

typ Rect()(geo): rec = {
    value: int
};

fun (Rect)area(): int = {
    return 1;
};

fun pick(T: geo)(value: T): T = {
    return value;
};

fun[] main(): int = {
    var rect: Rect = { value = 1 };
    return std::io::echo_int(pick(rect).area());
};
