pro[] build(): non = {
    var build = .build();
    build.meta({
        name = "generic_routine_cross_file_m1",
        version = "0.1.0",
    });

    var graph = build.graph();
    graph.add_exe({
        name = "generic_routine_cross_file_m1",
        root = "src/main.fol",
        fol_model = "memo",
    });
    return;
};
