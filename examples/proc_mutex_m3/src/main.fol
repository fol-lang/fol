use std: pkg = {"std"};

typ Counter: rec = {
    value: int,
};

fun[] worker(counter[mux]: Counter): int = {
    counter.lock();
    counter.value = counter.value + 1;
    return std::io::echo_int(counter.value);
};

fun[] coordinate(counter[mux]: Counter): int = {
    [>]worker(counter);
    [>]worker(counter);
    return 0;
};

fun[] main(): int = {
    var counter: Counter = { value = 0 };
    return coordinate(counter);
};
