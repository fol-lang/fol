pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_mem_ptr_raw_m3", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-mem-ptr-raw-m3",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
