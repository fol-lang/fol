pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_proc_await_in_memo_m4", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-proc-await-in-memo-m4",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
