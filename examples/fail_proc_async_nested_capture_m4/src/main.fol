use std: pkg = {"std"};

fun[] work(fail: bol): int / int = {
    when(fail) {
        case(true) { report 9; }
        * { return 7; }
    }
};

fun[] main(): int = {
    var pending = work(false) | async;
    var action = fun[](): int = {
        return (pending | await) || 0;
    };
    return 0;
};
