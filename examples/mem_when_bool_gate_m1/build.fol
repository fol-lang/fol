pro[] build(): non = {
    var build = .build();
    build.meta({ name = "mem_when_bool_gate_m1", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "mem-when-bool-gate-m1",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
