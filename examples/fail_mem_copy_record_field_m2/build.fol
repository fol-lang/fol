pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_mem_copy_record_field_m2", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-mem-copy-record-field-m2",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
