pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_standard_signature_m2", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail_standard_signature_m2",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    graph.add_run(app);
};
