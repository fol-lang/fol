pro[] build(): non = {
    var build = .build();
    build.meta({ name = "mem_nll_last_use_m2", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "mem-nll-last-use-m2",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
