pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_proc_channel_capture_rx_m2", version = "0.1.0" });
    build.add_dep({ alias = "std", source = "internal", target = "standard" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-proc-channel-capture-rx-m2",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
