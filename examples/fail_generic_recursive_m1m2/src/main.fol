// Negative boundary: a generic type whose field refers back to itself
// (`kids: vec[Tree[T]]`) has no finite runtime shape because it embeds the
// recursive value without indirection. V3 recursive data uses an explicit
// `@`-owned edge; this inline value-recursive form stays rejected instead of
// looping in lowering.
typ Tree(T): rec = {
    value: T,
    kids: vec[Tree[T]]
};

fun[] main(): int = {
    return 0;
};
