fun[] consume(pointer: ptr[int]): int = {
    return [drf]pointer;
};

fun[] main(): int = {
    var first: int = 1;
    var second: int = 2;
    var[mut] pointer: ptr[int] = [ref]first;
    var old: int = consume([mov]pointer);
    pointer = [ref]second;
    pointer = pointer;
    when(old + [drf]pointer) {
        case(3) { return 0; }
        * { panic "owner reinitialization failed"; }
    }
};
