fun[] consume(pointer: ptr[int]): int = {
    return *pointer;
};

fun[] main(): int = {
    var first: int = 1;
    var second: int = 2;
    var[mut] pointer: ptr[int] = &first;
    var old: int = consume(pointer);
    pointer = &second;
    pointer = pointer;
    when(old + *pointer) {
        case(3) { return 0; }
        * { panic "owner reinitialization failed"; }
    }
};
