use std: pkg = {"std"};

typ File()(fin): rec = { descriptor: int };

pro (File)finalize(): non = {
    var cleaned: int = std::io::echo_int(7);
    return;
};

pro[] consume(handle: File): non = {
    return;
};

// A `fin` value owns a foreign resource that is not proven thread-safe, so it
// is not `send` and cannot cross a spawn/async task boundary (V3_MEM §8.1).
fun[] main(): int = {
    var handle: File = { descriptor = 3 };
    [spn]consume([mov]handle);
    return 0;
};
