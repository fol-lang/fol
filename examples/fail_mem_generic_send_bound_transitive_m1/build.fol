pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_mem_generic_send_bound_transitive_m1", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail-mem-generic-send-bound-transitive-m1",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
